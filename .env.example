# INVINCIBLE Configuration
# Copy this file to .env and fill in your actual values

# Required: Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=invincible_docs
FEEDBACK_COLLECTION=invincible_feedback
MEMORY_COLLECTION=invincible_memory

# Model Configuration
EMBEDDING_MODEL=models/gemini-embedding-001
GENERATION_MODEL=models/gemini-flash-lite-latest
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# RAG Parameters
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RETRIEVAL=10
TOP_K_RERANKED=4
MAX_MEMORY_TURNS=10
OCR_MIN_TEXT_THRESHOLD=40
